[Unit]
Description=Care4U Flask App (Gunicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=www-data
WorkingDirectory=/var/www/care4u
Environment="PATH=/var/www/care4u/.venv/bin"
EnvironmentFile=/var/www/care4u/.env
ExecStart=/var/www/care4u/.venv/bin/gunicorn --config /var/www/care4u/deploy/gunicorn.conf.py ${APP_MODULE:-app:app}

Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
