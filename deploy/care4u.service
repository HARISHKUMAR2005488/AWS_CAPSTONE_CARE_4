[Unit]
Description=Care4U Flask App (Gunicorn) — HTTPS via Nginx
After=network.target

[Service]
Type=simple
User=ec2-user
Group=nginx
WorkingDirectory=/var/www/care4u
Environment="PATH=/var/www/care4u/.venv/bin"
EnvironmentFile=/var/www/care4u/.env
ExecStart=/var/www/care4u/.venv/bin/gunicorn --config /var/www/care4u/deploy/gunicorn.conf.py app_aws:app

Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
